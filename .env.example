# ── OpenAI ──────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...votre-cle-openai...
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-ada-002

# ── Base de données ──────────────────────────────────────────────
# === AVEC DOCKER COMPOSE ===
#   DB_HOST=postgres    (nom du service Docker)
#   DB_PORT=5432        (port interne du conteneur)
#   Exposed on host: 5433
#
# === SANS DOCKER (local) ===
#   DB_HOST=localhost
#   DB_PORT=5433        (ou votre port PostgreSQL local)
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=bnm_password_changez_moi
DB_HOST=localhost
DB_PORT=5433

# ── JWT ─────────────────────────────────────────────────────────
# Générer : python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=changez_moi_en_production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ── Microservices (local sans Docker — optionnel) ────────────────
# Avec Docker : le gateway sur le port 8000
# Sans Docker : utiliser les URLs locales
AUTH_SERVICE_URL=http://localhost:8001
CHAT_SERVICE_URL=http://localhost:8002
TICKET_SERVICE_URL=http://localhost:8003
DOCUMENT_SERVICE_URL=http://localhost:8004
ADMIN_SERVICE_URL=http://localhost:8005
BNM_DATA_DIR=.
